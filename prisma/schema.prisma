generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Project {
  id             String   @id @default(cuid())
  title          String
  description    String?
  status         String   @default("ACTIVE")
  priority       String   @default("MEDIUM")
  dueDate        DateTime?
  progressMode   String   @default("AUTO")
  manualProgress Int?
  orderIndex     Int      @default(0)
  tasks          Task[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([orderIndex])
}

model Task {
  id                String   @id @default(cuid())
  title             String
  description       String?
  category          String?
  priority          String   @default("MEDIUM")
  dueDate           DateTime?
  estimatedMinutes  Int?
  status            String   @default("INBOX")
  fearLevel         Int?
  resistanceLevel   Int?
  clarityLevel      Int?
  painLevel         Int?
  startDifficulty   Int?
  resistanceReasons String?
  resistanceNote    String?
  contactStep       String?
  tinyStep          String?
  normalStep        String?
  progressLogs      TaskProgressLog[]
  dailyReviews      DailyReview[] @relation("DailyReviewToTask")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // 新增字段 - Project 关联
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // 新增字段 - 树状结构
  parentTaskId   String?
  parentTask     Task?        @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subTasks       Task[]       @relation("TaskHierarchy")

  // 新增字段 - 任务类型和排序
  taskType       String       @default("TASK")
  orderIndex     Int          @default(0)
  progressWeight Int          @default(1)
  manualProgress Int?
  isExpanded     Boolean      @default(true)

  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@index([projectId])
  @@index([parentTaskId])
  @@index([taskType])
  @@index([orderIndex])
}

model TaskProgressLog {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actionType String
  note      String?
  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([actionType])
  @@index([createdAt])
}

model DailyReview {
  id                String   @id @default(cuid())
  date              DateTime @unique
  mostAvoidedTaskId String?
  mostAvoidedTask   Task?    @relation("DailyReviewToTask", fields: [mostAvoidedTaskId], references: [id], onDelete: SetNull)
  didStart          Boolean?
  blockingReason    String?
  effectiveStarter  String?
  actualPainLevel   Int?
  painComparison    String?
  note              String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([date])
}

model PointTransaction {
  id         String   @id @default(cuid())
  sourceType String
  sourceId   String?
  delta      Int
  reason     String
  createdAt  DateTime @default(now())

  @@index([sourceType])
  @@index([createdAt])
}
